# Public site with automatic HTTPS (Let's Encrypt via DuckDNS domain).
spectral160.duckdns.org {
	root * /srv
	encode zstd gzip
	file_server

	@media {
		path *.jpg *.jpeg *.png *.gif *.webp *.svg *.ico *.mp4 *.webm
	}
	header @media Cache-Control "public, max-age=86400"

	log {
		output stdout
		format console
	}
}

# Local/LAN plain-HTTP access + container healthcheck target.
http://localhost {
	root * /srv
	encode zstd gzip
	file_server
}
